# Copy to .env and fill in for local development / Railway variables

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bullseye
FMP_API_KEY=your_fmp_key_here
OPENAI_API_KEY=your_openai_key_here
OPENAI_MODEL=gpt-4o-mini
MOCK_MODE=false
TOKENS_PER_PREDICTION=250
INITIAL_TOKEN_GRANT=1000
FREE_DAILY_TOKEN_GRANT=500
ADMIN_CRON_KEY=change-me-in-production
CORS_ORIGINS=*
